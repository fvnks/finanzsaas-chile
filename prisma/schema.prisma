generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String        @id @default(uuid())
  email              String        @unique
  password           String
  name               String
  role               String        @default("USER")
  allowedSections    String[]
  assignedProjectIds String[]
  activeCompanyId    String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  dailyReports       DailyReport[]
  planMarks          PlanMark[]
  timeEntries        TimeEntry[]
  companies          Company[]     @relation("UserCompanies")
}

model Company {
  id                    String                @id @default(uuid())
  rut                   String                @unique
  name                  String
  logoUrl               String?
  address               String?
  email                 String?
  phone                 String?
  website               String?
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  modules               String[]
  planId                String?
  planStatus            String                @default("ACTIVE")
  primaryColor          String?               @default("#2563eb")
  subscriptionStartedAt DateTime?
  subscriptionEndsAt    DateTime?
  lastPaymentAt         DateTime?
  billingCycleMonths    Int                   @default(1)
  bankAccounts          BankAccount[]
  clients               Client[]
  monthlyInfo           ClientMonthlyInfo[]
  plan                  SubscriptionPlan?     @relation(fields: [planId], references: [id])
  costCenters           CostCenter[]
  crews                 Crew[]
  DailyReport           DailyReport[]
  reportTemplates       ReportTemplate[]
  documents             Document[]
  requirements          DocumentRequirement[]
  epps                  Epp[]
  paidExpenses          Expense[]             @relation("PaidExpenses")
  receivedExpenses      Expense[]             @relation("ReceivedExpenses")
  inventoryMovements    InventoryMovement[]
  invoices              Invoice[]
  jobTitles             JobTitle[]
  leads                 Lead[]
  emailTemplates        EmailTemplate[]
  payments              Payment[]
  Plan                  Plan[]
  Product               Product[]
  projects              Project[]
  purchaseOrders        PurchaseOrder[]
  quotes                Quote[]
  suppliers             Supplier[]
  tools                 Tool[]
  Warehouse             Warehouse[]
  workers               Worker[]
  users                 User[]                @relation("UserCompanies")
}

model Client {
  id                 String                @id @default(uuid())
  rut                String
  name               String
  email              String?
  phone              String?
  address            String?
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  companyId          String
  portalToken        String?               @unique @default(uuid())
  company            Company               @relation(fields: [companyId], references: [id])
  monthlyInfo        ClientMonthlyInfo[]
  documents          Document[]
  documentCategories DocumentCategory[]
  requirements       DocumentRequirement[]
  invoices           Invoice[]
  projects           Project[]

  @@unique([rut, companyId])
}

model Project {
  id                   String                @id @default(uuid())
  name                 String
  description          String?
  status               String                @default("ACTIVE")
  clientId             String?
  progress             Int                   @default(0)
  budget               Float                 @default(0)
  address              String?
  startDate            DateTime?
  endDate              DateTime?
  workerIds            String[]
  costCenterIds        String[] @default([])
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  companyId            String
  crews                Crew[]
  dailyReports         DailyReport[]
  documents            Document[]
  expenseDistributions ExpenseDistribution[]
  inventoryMovements   InventoryMovement[]
  invoices             Invoice[]
  plans                Plan[]
  milestones           ProjectMilestone[]
  timeEntries          TimeEntry[]
  client               Client?               @relation(fields: [clientId], references: [id])
  company              Company               @relation(fields: [companyId], references: [id])
  purchaseOrders       PurchaseOrder[]
}

model ProjectMilestone {
  id          String   @id @default(uuid())
  projectId   String
  name        String
  description String?
  status      String   @default("PENDING") // PENDING, IN_PROGRESS, COMPLETED, DELAYED
  dueDate     DateTime?
  completedAt DateTime?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model TimeEntry {
  id        String   @id @default(uuid())
  projectId String
  workerId  String
  userId    String
  date      DateTime
  hours     Float    @default(0)
  description String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  worker    Worker   @relation(fields: [workerId], references: [id])
  user      User     @relation(fields: [userId], references: [id])
}

model CostCenter {
  id                   String                @id @default(uuid())
  code                 String
  name                 String
  budget               Float                 @default(0)
  createAt             DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  companyId            String
  company              Company               @relation(fields: [companyId], references: [id])
  expenseDistributions ExpenseDistribution[]
  invoices             Invoice[]
  plans                Plan[]

  @@unique([code, companyId])
}

model Worker {
  id              String           @id @default(uuid())
  rut             String
  name            String
  role            String?
  specialty       String?
  email           String?
  phone           String?
  experienceYears Int?
  certifications  String[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  companyId       String
  eppDeliveries   EppDelivery[]
  expenses        Expense[]
  toolAssignments ToolAssignment[]
  company         Company          @relation(fields: [companyId], references: [id])
  crews           Crew[]           @relation("CrewWorkers")
  planMarks       PlanMark[]       @relation("PlanMarkWorkers")
  timeEntries     TimeEntry[]

  @@unique([rut, companyId])
}

model Crew {
  id        String   @id @default(uuid())
  name      String
  role      String?
  projectId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  project   Project? @relation(fields: [projectId], references: [id])
  workers   Worker[] @relation("CrewWorkers")
}

model JobTitle {
  id          String   @id @default(uuid())
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id])

  @@unique([name, companyId])
}

model Invoice {
  id                  String        @id @default(uuid())
  number              String
  date                DateTime
  dueDate             DateTime?
  status              String        @default("DRAFT")
  type                String
  emissionType        String
  purchaseOrderNumber String?
  dispatchGuideNumber String?
  netAmount           Float
  taxAmount           Float
  totalAmount         Float
  clientId            String?
  supplierId          String?
  projectId           String?
  costCenterId        String?
  relatedInvoiceId    String?
  isPaid              Boolean       @default(false)
  paymentStatus       String        @default("PENDING")
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  companyId           String
  hesNumber           String?
  paymentDate         DateTime?
  currency            String        @default("CLP")
  exchangeRate        Float         @default(1)
  client              Client?       @relation(fields: [clientId], references: [id])
  supplier            Supplier?     @relation(fields: [supplierId], references: [id])
  company             Company       @relation(fields: [companyId], references: [id])
  costCenter          CostCenter?   @relation(fields: [costCenterId], references: [id])
  project             Project?      @relation(fields: [projectId], references: [id])
  relatedInvoice      Invoice?      @relation("InvoiceRelation", fields: [relatedInvoiceId], references: [id])
  relatedByInvoices   Invoice[]     @relation("InvoiceRelation")
  items               InvoiceItem[]
  payments            Payment[]
  expenses            Expense[]
}

model Payment {
  id        String   @id @default(uuid())
  amount    Float
  date      DateTime @default(now())
  method    String   @default("TRANSFER")
  reference String?
  comment   String?
  invoiceId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  invoice   Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

model Supplier {
  id          String   @id @default(uuid())
  rut         String   @unique
  razonSocial String
  fantasyName String?
  email       String?
  phone       String?
  address     String?
  category    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id])
  invoices    Invoice[]
}

model InvoiceItem {
  id          String  @id @default(uuid())
  description String
  quantity    Float
  unitPrice   Float
  total       Float
  invoiceId   String
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

model DailyReport {
  id         String   @id @default(uuid())
  userId     String
  date       DateTime
  content    String
  projectId  String?
  status     String   @default("DRAFT") // DRAFT, PENDING_APPROVAL, APPROVED, REJECTED
  attachments String[] @default([])
  templateId String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  companyId  String
  company    Company     @relation(fields: [companyId], references: [id])
  project    Project?    @relation(fields: [projectId], references: [id])
  user       User        @relation(fields: [userId], references: [id])
  template   ReportTemplate? @relation(fields: [templateId], references: [id])
}

model ReportTemplate {
  id        String   @id @default(uuid())
  name      String
  content   String
  companyId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  company   Company  @relation(fields: [companyId], references: [id])
  reports   DailyReport[]
}

model PurchaseOrder {
  id        String              @id @default(uuid())
  number    String
  provider  String
  date      DateTime
  status    String              @default("PENDING")
  projectId String?
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
  companyId String
  company   Company             @relation(fields: [companyId], references: [id])
  project   Project?            @relation(fields: [projectId], references: [id])
  items     PurchaseOrderItem[]

  @@unique([number, companyId])
}

model PurchaseOrderItem {
  id              String        @id @default(uuid())
  description     String
  quantity        Float
  unitPrice       Float
  total           Float
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
}

model Document {
  id            String               @id @default(uuid())
  name          String
  url           String
  type          String
  projectId     String?
  clientId      String?
  createdAt     DateTime             @default(now())
  requirementId String?
  status        String               @default("PENDING")
  companyId     String
  client        Client?              @relation(fields: [clientId], references: [id])
  company       Company              @relation(fields: [companyId], references: [id])
  project       Project?             @relation(fields: [projectId], references: [id])
  requirement   DocumentRequirement? @relation(fields: [requirementId], references: [id])
}

model DocumentRequirement {
  id          String            @id @default(uuid())
  name        String
  description String?
  month       Int?
  year        Int?
  status      String            @default("PENDING")
  dueDate     DateTime?
  clientId    String
  categoryId  String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  companyId   String
  documents   Document[]
  category    DocumentCategory? @relation(fields: [categoryId], references: [id])
  client      Client            @relation(fields: [clientId], references: [id], onDelete: Cascade)
  company     Company           @relation(fields: [companyId], references: [id])
}

model DocumentCategory {
  id           String                @id @default(uuid())
  name         String
  color        String?
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  clientId     String
  client       Client                @relation(fields: [clientId], references: [id], onDelete: Cascade)
  requirements DocumentRequirement[]

  @@unique([name, clientId])
}

model Product {
  id          String              @id @default(uuid())
  code        String?
  name        String
  description String?
  type        String              @default("GOOD")
  category    String?
  unit        String              @default("UN")
  price       Float               @default(0)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  companyId   String
  movements   InventoryMovement[]
  company     Company             @relation(fields: [companyId], references: [id])
  stocks      Stock[]

  @@unique([code, companyId])
}

model Warehouse {
  id            String              @id @default(uuid())
  name          String
  location      String?
  manager       String?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  companyId     String
  movementsFrom InventoryMovement[] @relation("MovementFromWarehouse")
  movementsTo   InventoryMovement[] @relation("MovementToWarehouse")
  stocks        Stock[]
  company       Company             @relation(fields: [companyId], references: [id])
}

model Stock {
  id          String    @id @default(uuid())
  quantity    Float     @default(0)
  minStock    Float     @default(0)
  productId   String
  warehouseId String
  updatedAt   DateTime  @updatedAt
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  @@unique([productId, warehouseId])
}

model InventoryMovement {
  id              String     @id @default(uuid())
  type            String
  quantity        Float
  date            DateTime   @default(now())
  description     String?
  projectId       String?
  createdAt       DateTime   @default(now())
  companyId       String
  fromWarehouseId String?
  productId       String
  toWarehouseId   String?
  company         Company    @relation(fields: [companyId], references: [id])
  fromWarehouse   Warehouse? @relation("MovementFromWarehouse", fields: [fromWarehouseId], references: [id])
  product         Product    @relation(fields: [productId], references: [id])
  project         Project?   @relation(fields: [projectId], references: [id])
  toWarehouse     Warehouse? @relation("MovementToWarehouse", fields: [toWarehouseId], references: [id])
}

model ClientMonthlyInfo {
  id        String    @id @default(uuid())
  clientId  String
  month     Int
  year      Int
  edpDate   DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  companyId String
  client    Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  company   Company   @relation(fields: [companyId], references: [id])

  @@unique([clientId, month, year])
}

model Plan {
  id                 String      @id @default(uuid())
  name               String
  imageUrl           String
  projectId          String?
  costCenterId       String?
  stages             Int         @default(1)
  systemType         String?
  installationType   String?
  installationDetail String?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  companyId          String
  company            Company     @relation(fields: [companyId], references: [id])
  costCenter         CostCenter? @relation(fields: [costCenterId], references: [id])
  project            Project?    @relation(fields: [projectId], references: [id])
  marks              PlanMark[]
}

model PlanMark {
  id        String   @id @default(uuid())
  planId    String
  userId    String
  x         Float
  y         Float
  points    Json?
  type      String   @default("POINT")
  date      DateTime @default(now())
  meters    Float    @default(0)
  comment   String?
  imageUrl  String?
  stage     Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  plan      Plan     @relation(fields: [planId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])
  workers   Worker[] @relation("PlanMarkWorkers")
}

model Expense {
  id              String                @id @default(uuid())
  description     String
  amount          Float
  category        String?
  date            DateTime
  originCompanyId String
  targetCompanyId String
  workerId        String?
  invoiceNumber   String?
  status          String                @default("PENDING")
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  currency        String                @default("CLP")
  exchangeRate    Float                 @default(1)
  originCompany   Company               @relation("PaidExpenses", fields: [originCompanyId], references: [id])
  targetCompany   Company               @relation("ReceivedExpenses", fields: [targetCompanyId], references: [id])
  worker          Worker?               @relation(fields: [workerId], references: [id])
  invoiceId       String?
  invoice         Invoice?              @relation(fields: [invoiceId], references: [id])
  distributions   ExpenseDistribution[]
}

model ExpenseDistribution {
  id           String      @id @default(uuid())
  amount       Float
  expenseId    String
  projectId    String?
  costCenterId String?
  costCenter   CostCenter? @relation(fields: [costCenterId], references: [id])
  expense      Expense     @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  project      Project?    @relation(fields: [projectId], references: [id])
}

model Tool {
  id                  String            @id @default(uuid())
  name                String
  brand               String?
  model               String?
  serialNumber        String?
  status              String            @default("AVAILABLE")
  lastMaintenanceDate DateTime?
  nextMaintenanceDate DateTime?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  companyId           String
  company             Company           @relation(fields: [companyId], references: [id])
  assignments         ToolAssignment[]
  maintenances        ToolMaintenance[]
}

model ToolMaintenance {
  id          String   @id @default(uuid())
  date        DateTime
  description String
  cost        Float    @default(0)
  provider    String?
  toolId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tool        Tool     @relation(fields: [toolId], references: [id], onDelete: Cascade)
}

model Epp {
  id          String        @id @default(uuid())
  name        String
  description String?
  stock       Float         @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  companyId   String
  company     Company       @relation(fields: [companyId], references: [id])
  deliveries  EppDelivery[]
}

model EppDelivery {
  id        String   @id @default(uuid())
  quantity  Float    @default(1)
  date      DateTime @default(now())
  notes     String?
  workerId  String
  eppId     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  epp       Epp      @relation(fields: [eppId], references: [id], onDelete: Cascade)
  worker    Worker   @relation(fields: [workerId], references: [id], onDelete: Cascade)
}

model ToolAssignment {
  id         String    @id @default(uuid())
  assignedAt DateTime  @default(now())
  returnedAt DateTime?
  notes      String?
  workerId   String
  toolId     String
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  tool       Tool      @relation(fields: [toolId], references: [id], onDelete: Cascade)
  worker     Worker    @relation(fields: [workerId], references: [id], onDelete: Cascade)
}

model SubscriptionPlan {
  id           String    @id @default(uuid())
  name         String
  description  String?
  price        Float     @default(0)
  maxUsers     Int       @default(1)
  modules      String[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  features     String[]
  maxStorageGB Int?      @default(5)
  companies    Company[]
}

model Lead {
  id            String   @id @default(uuid())
  name          String
  companyName   String?
  email         String?
  phone         String?
  status        String   @default("NEW")
  source        String?
  notes         String?
  score         Int      @default(0) // 0-100
  grade         String?  // A, B, C
  estimatedValue Float?  @default(0)
  assignedTo    String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  companyId     String
  company       Company  @relation(fields: [companyId], references: [id])
  quotes        Quote[]
  activities    LeadActivity[]
}

model LeadActivity {
  id        String   @id @default(uuid())
  leadId    String
  type      String   // CALL, MEETING, EMAIL, NOTE, STATUS_CHANGE, QUOTE_SENT
  content   String
  userId    String?
  createdAt DateTime @default(now())
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
}

model EmailTemplate {
  id        String   @id @default(uuid())
  name      String
  subject   String
  body      String
  companyId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  company   Company  @relation(fields: [companyId], references: [id])
}

model Quote {
  id          String      @id @default(uuid())
  number      String
  date        DateTime    @default(now())
  validUntil  DateTime?
  status      String      @default("DRAFT")
  netAmount   Float       @default(0)
  taxAmount   Float       @default(0)
  totalAmount Float       @default(0)
  notes       String?
  leadId      String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  companyId   String
  company     Company     @relation(fields: [companyId], references: [id])
  lead        Lead?       @relation(fields: [leadId], references: [id])
  items       QuoteItem[]
}

model QuoteItem {
  id          String @id @default(uuid())
  description String
  quantity    Float  @default(1)
  unitPrice   Float  @default(0)
  total       Float  @default(0)
  quoteId     String
  quote       Quote  @relation(fields: [quoteId], references: [id], onDelete: Cascade)
}

model BankAccount {
  id           String            @id @default(uuid())
  name         String
  number       String?
  currency     String            @default("CLP")
  balance      Float             @default(0)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  companyId    String
  company      Company           @relation(fields: [companyId], references: [id])
  transactions BankTransaction[]
}

model BankTransaction {
  id            String      @id @default(uuid())
  date          DateTime    @default(now())
  type          String
  amount        Float
  description   String?
  reference     String?
  category      String?
  bankAccountId String
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  bankAccount   BankAccount @relation(fields: [bankAccountId], references: [id], onDelete: Cascade)
}

model ExchangeRate {
  id        String   @id @default(uuid())
  date      DateTime @default(now())
  currency  String
  value     Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([date, currency])
}
